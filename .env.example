# ─── Required ────────────────────────────────────────────────────
# Anthropic API key — powers translation + summaries.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Deepgram API key — powers live speech-to-text with speaker diarization.
# Get one at https://console.deepgram.com/
DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Optional ────────────────────────────────────────────────────
# Override the Claude models used. Defaults are shown below.
# Translation fires on every speech update, so a fast model is used by default.
# TRANSLATION_MODEL=claude-haiku-4-5
# SUMMARY_MODEL=claude-sonnet-4-6

# ─── Live meeting bot (optional) ─────────────────────────────────
# Enables "Send a bot to a meeting". Requires the separate
# lengualive-bot-worker service to be deployed. Without these two,
# /api/meeting returns 503 and the rest of the app works normally.
# BOT_WORKER_URL    — the worker's public URL, e.g. https://xxx.fly.dev
# WORKER_API_TOKEN  — shared secret; must match the worker's value
# BOT_WORKER_URL=
# WORKER_API_TOKEN=
